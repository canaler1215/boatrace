# ── PostgreSQL 接続文字列 ──────────────────────────────────────────────────────
# [Neon] https://console.neon.tech → プロジェクト → Connection String
# [ローカル Docker] postgresql://boatrace:boatrace@localhost:5432/boatrace
# ローカル Docker の場合はこちら（変更不要）:
DATABASE_URL=postgresql://boatrace:boatrace@localhost:5432/boatrace
# Neon の場合は上を消してこちらを使う:
# DATABASE_URL=postgresql://neondb_owner:<password>@<endpoint>.neon.tech/neondb?sslmode=require&channel_binding=require

# ── ログレベル ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Discord 通知（任意） ────────────────────────────────────────────────────────
# Discord サーバー → チャンネル設定 → インテグレーション → Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
